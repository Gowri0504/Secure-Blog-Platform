    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^6.2.0",
    "@prisma/client": "^5.12.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "nestjs-pino": "^4.0.0",
